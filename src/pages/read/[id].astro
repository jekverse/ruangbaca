---
import Layout from '../../layouts/Layout.astro';
import books from '../../data/books.json';
import PdfViewer from '../../components/PdfViewer';

export async function getStaticPaths() {
	return books.map((book) => {
		return {
			params: { id: book.id },
			props: { book },
		};
	});
}

const { book } = Astro.props;
---

<Layout title={book.title}>
	<!-- Sidebar -->
	<aside class="w-64 bg-white border-r border-gray-200 p-6 hidden md:flex flex-col shrink-0">
		<div class="mb-8">
			<h1 class="text-2xl font-bold tracking-tight text-indigo-600">ruangbaca</h1>
			<p class="text-sm text-gray-500 mt-1">Minimalist PDF Library</p>
		</div>
		<nav class="flex-1">
			<ul class="space-y-2">
				<li>
					<a href="/" class="flex items-center px-4 py-2 text-sm font-medium text-gray-600 hover:text-indigo-700 hover:bg-indigo-50 rounded-lg transition-colors">
						<svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
						</svg>
						Back to Library
					</a>
				</li>
			</ul>
		</nav>
		<div class="mt-auto pt-6 border-t border-gray-100">
			<h3 class="text-sm font-semibold text-gray-900 mb-2">Now Reading</h3>
			<p class="text-sm text-gray-600 truncate" title={book.title}>{book.title}</p>
		</div>
	</aside>

	<!-- Main Area / Reader -->
	<main class="flex-1 bg-gray-100 h-screen overflow-hidden flex flex-col relative">
		<!-- Mobile Header -->
		<header class="bg-white border-b border-gray-200 p-4 flex items-center md:hidden shrink-0 z-10 shadow-sm">
			<a href="/" class="mr-4 text-gray-500 hover:text-indigo-600 transition-colors">
				<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
				</svg>
			</a>
			<h1 class="text-lg font-semibold text-gray-900 truncate flex-1">{book.title}</h1>
		</header>
		
		<!-- PDF Viewer Container -->
		<div class="flex-1 overflow-auto w-full h-full custom-scrollbar">
			<PdfViewer client:only="react" pdfPath={book.pdfPath} />
		</div>
	</main>
</Layout>

<style>
	/* Custom scrollbar for webkit */
	.custom-scrollbar::-webkit-scrollbar {
		width: 8px;
		height: 8px;
	}
	.custom-scrollbar::-webkit-scrollbar-track {
		background: #f1f1f1; 
	}
	.custom-scrollbar::-webkit-scrollbar-thumb {
		background: #c1c1c1; 
		border-radius: 4px;
	}
	.custom-scrollbar::-webkit-scrollbar-thumb:hover {
		background: #a8a8a8; 
	}
</style>
